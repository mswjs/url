{
  "type": "module",
  "name": "@msw/url",
  "version": "1.0.0",
  "description": "Utilities for working with URLs.",
  "imports": {
    "#src/*": "./src/*",
    "#tests/*": "./tests/*"
  },
  "exports": {
    ".": "./build/index.mjs"
  },
